# Supabase Configuration (Required)
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key for server-side operations (bypasses RLS)
# Required for production; falls back to anon key in dev if unset
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Session secret for signing SSO session JWTs (Required)
SESSION_SECRET=generate-a-random-64-char-hex-string

# SSO Configuration (Required for authentication)
CHORUSING_SSO_SECRET=your-discourse-connect-secret
NEXT_PUBLIC_APP_URL=https://chorusing.app

# Admin Configuration (Optional)
# Comma-separated list of Refold user IDs that have admin privileges
# Admins can edit and delete any clips, regardless of ownership
ADMIN_REFOLD_IDS=

# File Upload Limits (Hardcoded in code, shown for reference)
# Current limits: 2MB max file size
# Supported formats: mp3, wav, m4a, ogg, webm
